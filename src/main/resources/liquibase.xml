<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd" objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">

  <changeSet id="1" author="yw">
    <createTable tableName="Frage">
      <column name="frageId" type="uuid">
        <constraints primaryKey="true" nullable="false" primaryKeyName="frage_pk"/>
      </column>
      <column name="fragetext" type="varchar(255)"/>
    </createTable>
  </changeSet>

  <changeSet id="2" author="yw">
    <createTable tableName="Antwort">
      <column name="antwortId" type="uuid">
        <constraints primaryKey="true" nullable="false" primaryKeyName="antwort_pk"/>
      </column>
      <column name="antworttext" type="varchar(255)"/>
      <column name="frageId" type="uuid"/>
    </createTable>
  </changeSet>

  <changeSet id="3" author="yw">
    <createTable tableName="Kommentar">
      <column name="kommentarId" type="uuid">
        <constraints primaryKey="true" nullable="false" primaryKeyName="kommentar_pk"/>
      </column>
      <column name="kommentartext" type="varchar(255)"/>
      <column name="antwortId" type="uuid"/>
      <column name="frageId" type="uuid"/>
    </createTable>
  </changeSet>

  <changeSet id="4" author="yw">
    <createTable tableName="Vote">
      <column name="voteId" type="uuid">
        <constraints primaryKey="true" nullable="false" primaryKeyName="vote_pk"/>
      </column>
      <column name="voting" type="boolean"/>
      <column name="antwortId" type="uuid"/>
      <column name="frageId" type="uuid"/>
      <column name="kommentarId" type="uuid"/>
    </createTable>
  </changeSet>

  <changeSet id="5" author="jmo">
    <addForeignKeyConstraint baseTableName="Antwort" baseColumnNames="frageId"
                             constraintName="fk_antwort_frage"
                             referencedTableName="Frage"
                             referencedColumnNames="frageId"/>
  </changeSet>

  <changeSet id="6" author="jmo">
    <addForeignKeyConstraint baseTableName="Kommentar" baseColumnNames="antwortId"
                             constraintName="fk_kommentar_antwort"
                             referencedTableName="Antwort"
                             referencedColumnNames="antwortId"/>
  </changeSet>

  <changeSet id="7" author="jmo">
    <addForeignKeyConstraint baseTableName="Kommentar" baseColumnNames="frageId"
                             constraintName="fk_kommentar_frage"
                             referencedTableName="Frage"
                             referencedColumnNames="frageId"/>
  </changeSet>

  <changeSet id="8" author="jmo">
    <addForeignKeyConstraint baseTableName="Vote" baseColumnNames="antwortId"
                             constraintName="fk_vote_antwort"
                             referencedTableName="Antwort"
                             referencedColumnNames="antwortId"/>
  </changeSet>

  <changeSet id="9" author="jmo">
    <addForeignKeyConstraint baseTableName="Vote" baseColumnNames="frageId"
                             constraintName="fk_vote_frage"
                             referencedTableName="Frage"
                             referencedColumnNames="frageId"/>
  </changeSet>

  <changeSet id="10" author="jmo">
    <addForeignKeyConstraint baseTableName="Vote" baseColumnNames="kommentarId"
                             constraintName="fk_vote_kommentar"
                             referencedTableName="Kommentar"
                             referencedColumnNames="kommentarId"/>
  </changeSet>


  <changeSet id="11" author="fsk">
    <addColumn tableName="Frage">
      <column name="ersteller_name" type="varchar(255)"/>
    </addColumn>
  </changeSet>

  <changeSet id="12" author="fsk">
    <addColumn tableName="Frage">
      <column name="beschreibung" type="varchar(2000)"/>
    </addColumn>
  </changeSet>

</databaseChangeLog>
